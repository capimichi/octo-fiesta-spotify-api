# Application Core Settings
APP_NAME=octofiestaspotifyapi
DEBUG=0

# API Server Settings
API_HOST=127.0.0.1
API_PORT=8000
API_HOST_PORT=8000
API_CONTAINER_PORT=8000

# Directory Settings (relative to project root)
LOG_DIR=var/log
DOWNLOAD_DIR=var/downloads
TEMP_DIR=var/tmp

# Logger File Paths (relative to LOG_DIR or full path if preferred)
APP_LOG_FILE=var/log/app.log
API_LOG_FILE=var/log/api.log
SPOTIFY_CLIENT_LOG_FILE=var/log/spotify-client.log
DOWNLOAD_LOG_FILE=var/log/download.log
BROWSER_LOG_FILE=var/log/browser.log

# Spotify Browser Client Settings
SPOTIFY_BROWSER_ENABLED=1
SPOTIFY_BROWSER_TIMEOUT_SECONDS=30
SPOTIFY_SESSION_STORAGE_PATH=var/tmp/spotify-session # Path for Playwright browser persistent context

# Spotiflac Downloader Settings
SPOTIFLAC_ENABLED=1
SPOTIFLAC_BINARY=spotiflac # Ensure 'spotiflac' is in PATH or provide full path
SPOTIFLAC_OUTPUT_DIR=var/downloads # Directory where spotiflac saves downloaded files
SPOTIFLAC_TIMEOUT_SECONDS=600 # Max time in seconds to wait for spotiflac download
